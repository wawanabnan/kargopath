# Production Environment Variables Template
# Copy this file to .env and update with your actual values

# Django Settings
SECRET_KEY=CHANGE-THIS-TO-A-SECURE-RANDOM-KEY-MINIMUM-50-CHARACTERS
DEBUG=False
ALLOWED_HOSTS=your-vps-ip,yourdomain.com

# Database (PostgreSQL - RECOMMENDED for production)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=kargopath
DB_USER=kargopath_user
DB_PASSWORD=your-secure-password-change-this
DB_HOST=localhost
DB_PORT=5432

# CORS Settings (Frontend URL)
CORS_ALLOWED_ORIGINS=http://your-vps-ip,https://yourdomain.com

# Email Settings (optional)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Security Settings (Production)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
